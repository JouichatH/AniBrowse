# values in {NAME} syntax are provided by python using .replace()
# 
[Unit]
Description=Ani-Browse Background Worker
After=network-online.target

[Service]
Type=simple
# Ensure you have the full path to your ani-browse executable
# Use `which ani-browse` to find it
ExecStart={EXECUTABLE} worker --log
Restart=always
RestartSec=30

[Install]
WantedBy=default.target
